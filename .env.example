# Copy this file to .env and fill in your real API key.
# .env is gitignored — never commit it.

# Required. Used for OCR (vision), embeddings, and answer generation.
OPENAI_API_KEY=

# Models — all default to the values below if left unset.
OCR_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
CHAT_MODEL=gpt-4o-mini

# Relevance threshold: top Chroma cosine-similarity score must meet or
# exceed this for the tool to answer instead of refusing. Range 0-1.
# Interim value 0.3, set at Checkpoint 1: observed scores separate cleanly into
# in-scope ~0.41-0.61 and out-of-scope ~0.06-0.07, so 0.5 was rejecting valid
# in-scope questions (e.g. "chest pain" @ 0.407). 0.3 sits in the gap. Final
# value to be confirmed against the eval set (Task 13).
SIMILARITY_THRESHOLD=0.3

# Chunking: fixed-size sliding window applied to the extracted document text.
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# Text extraction: native PDF text layer is tried first (via pymupdf) for
# each page; a page only falls back to OCR_MODEL (vision) if its native
# text has fewer than this many non-whitespace characters.
# Placeholder — tune empirically once the real corpus is in data/
# (see SPEC.md Open Questions / tasks/plan.md Task 2/3).
TEXT_LAYER_MIN_CHARS=100

# Set to true to bypass native extraction entirely and force every page
# through OCR_MODEL — useful for exercising the OCR path or a corpus known
# to be fully scanned.
FORCE_OCR=false

# Paths (relative to project root). Created at runtime if missing.
DATA_DIR=data
CHROMA_DIR=.chroma
TEXT_CACHE_DIR=.text_cache
